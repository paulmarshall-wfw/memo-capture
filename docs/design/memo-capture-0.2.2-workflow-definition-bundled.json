        "to": "ignored"
      },
      {
        "from": "needs_review",
        "to": "memo"
      },
      {
        "from": "memo",
        "to": "accepted"
      },
      {
        "from": "memo",
        "to": "failed"
      },
      {
        "from": "memo",
        "to": "ignored"
      },
      {
        "from": "memo",
        "to": "parked"
      },
      {
        "from": "memo",
        "to": "rejected"
      },
      {
        "from": "parked",
        "to": "accepted"
      },
      {
        "from": "parked",
        "to": "failed"
      },
      {
        "from": "parked",
        "to": "ignored"
      },
      {
        "from": "parked",
        "to": "memo"
      },
      {
        "from": "parked",
        "to": "rejected"
      },
      {
        "from": "failed",
        "to": "needs_review"
      },
      {
        "from": "rejected",
        "to": "memo"
      },
      {
        "from": "ignored",
        "to": "memo"
      }
    ]
  }
