{
  "schemaVersion": "0.7.0",
  "appName": "memo-capture",
  "workflowVersion": "0.2.2",
  "id": "memo-capture_workflow",
  "stateMachine": {
    "id": "memo_capture_state",
    "definitionVersion": "0.2.2"
  },
  "states": [
    {
      "id": "needs_review",
      "visible": true
    },
    {
      "id": "memo",
      "visible": true
    },
    {
      "id": "accepted",
      "visible": true
    },
    {
      "id": "parked",
      "visible": true
    },
    {
      "id": "rejected",
      "visible": true
    },
    {
      "id": "ignored",
      "visible": true
    },
    {
      "id": "failed",
      "visible": true
    }
  ],
  "actions": [
    {
      "id": "accepted.memo",
      "label": "Undo Acceptance",
      "from": "accepted",
      "to": "memo",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "review.failed",
      "label": "Fail",
      "from": "needs_review",
      "to": "failed",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "review.ignored",
      "label": "Ignore",
      "from": "needs_review",
      "to": "ignored",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "review.memo",
      "label": "Mark as New Memo",
      "from": "needs_review",
      "to": "memo",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "memo.accepted",
      "label": "Accept",
      "from": "memo",
      "to": "accepted",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "memo.failed",
      "label": "Fail",
      "from": "memo",
      "to": "failed",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "memo.ignored",
      "label": "Ignore",
      "from": "memo",
      "to": "ignored",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "memo.parked",
      "label": "Park",
      "from": "memo",
      "to": "parked",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "memo.rejected",
      "label": "Reject",
      "from": "memo",
      "to": "rejected",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "parked.accepted",
      "label": "Accept",
      "from": "parked",
      "to": "accepted",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "parked.failed",
      "label": "Fail",
      "from": "parked",
      "to": "failed",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "parked.ignored",
      "label": "Ignore",
      "from": "parked",
      "to": "ignored",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "parked.memo",
      "label": "Mark as Memo",
      "from": "parked",
      "to": "memo",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "parked.rejected",
      "label": "Reject",
      "from": "parked",
      "to": "rejected",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "failed.review",
      "label": "Review",
      "from": "failed",
      "to": "needs_review",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "rejected.memo",
      "label": "Mark as Memo",
      "from": "rejected",
      "to": "memo",
      "trigger": "user",
      "visible": true
    },
    {
      "id": "ignored.memo",
      "label": "Mark as Memo",
      "from": "ignored",
      "to": "memo",
      "trigger": "user",
      "visible": true
    }
  ],
  "buckets": [
    {
      "id": "review",
      "label": "Review",
      "visible": true,
      "states": [
        "needs_review"
      ]
    },
    {
      "id": "memos",
      "label": "Memos",
      "visible": true,
      "states": [
        "memo"
      ]
    },
    {
      "id": "accepted",
      "label": "Accepted",
      "visible": true,
      "states": [
        "accepted"
      ]
    },
    {
      "id": "parked",
      "label": "Parked",
      "visible": true,
      "states": [
        "parked"
      ]
    },
    {
      "id": "archive",
      "label": "Archive",
      "visible": true,
      "states": [
        "ignored",
        "rejected"
      ]
    },
    {
      "id": "failures",
      "label": "Failures",
      "visible": true,
      "states": [
        "failed"
      ]
    }
  ],
  "hooks": [
    {
      "id": "on_state_entry_accepted",
      "phase": "on_state_entry",
      "targetType": "state",
      "targetId": "accepted",
      "handlerKey": "create_accepted_snapshot"
    }
  ],
