# Desktop
VITE_MEMO_CAPTURE_API_URL=http://localhost:4788

# API
MEMO_CAPTURE_API_HOST=127.0.0.1
MEMO_CAPTURE_API_PORT=4788
MEMO_CAPTURE_LOG_LEVEL=debug
MEMO_CAPTURE_APP_VERSION=0.1.0
MEMO_CAPTURE_COMMIT_SHA=dev

# Database
DATABASE_URL=postgres://memo_capture:memo_capture@localhost:5432/memo_capture
MEMO_CAPTURE_MIGRATIONS_DIR=

# OIDC
MEMO_CAPTURE_AUTH_MODE=oidc
MEMO_CAPTURE_LOCAL_DEV_AUTH_ENABLED=false
MEMO_CAPTURE_LOCAL_DEV_AUTH_ISSUER=memo-capture-local-dev
MEMO_CAPTURE_LOCAL_DEV_AUTH_SUBJECT=local-dev-user
MEMO_CAPTURE_LOCAL_DEV_AUTH_EMAIL=local-dev@example.invalid
MEMO_CAPTURE_LOCAL_DEV_AUTH_DISPLAY_NAME=Local Dev User
OIDC_ISSUER_URL=https://example-issuer.invalid
OIDC_AUDIENCE=memo-capture-api
OIDC_CLIENT_ID=memo-capture-desktop
OIDC_JWKS_URL=https://example-issuer.invalid/.well-known/jwks.json

# S3-compatible object storage
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=local
OBJECT_STORAGE_BUCKET=memo-capture
OBJECT_STORAGE_LOCAL_ROOT=.memo-capture/object-storage
OBJECT_STORAGE_ACCESS_KEY_ID=replace-me
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-me

# AI/transcription providers
LLM_PROVIDER=disabled
LLM_MODEL=memo-capture-local-dev-expander-v1
LLM_ENDPOINT=
MEMO_EXPANSION_PROVIDER=disabled
MEMO_EXPANSION_MODEL=memo-capture-local-dev-expander-v1
MEMO_EXPANSION_ENDPOINT=
REVISE_MEMO_PROVIDER=disabled
REVISE_MEMO_MODEL=memo-capture-local-dev-expander-v1
REVISE_MEMO_ENDPOINT=
SUGGEST_NEW_MEMOS_PROVIDER=disabled
SUGGEST_NEW_MEMOS_MODEL=memo-capture-local-dev-expander-v1
SUGGEST_NEW_MEMOS_ENDPOINT=
SUGGEST_TAGS_PROVIDER=disabled
SUGGEST_TAGS_MODEL=memo-capture-local-dev-expander-v1
SUGGEST_TAGS_ENDPOINT=
OCR_PROVIDER=disabled
OCR_MODEL=
OCR_ENDPOINT=
OPENAI_COMPATIBLE_API_KEY=replace-me
TRANSCRIPTION_PROVIDER=whisper-cpp
TRANSCRIPTION_MODEL=base.en
WHISPER_CPP_MODE=cli
WHISPER_CPP_BINARY=/opt/homebrew/bin/whisper-cpp
WHISPER_CPP_MODEL_PATH=/Users/paulmarshall/Software Development/whisper.cpp/models/ggml-base.en.bin
WHISPER_CPP_FFMPEG_BINARY=/opt/homebrew/bin/ffmpeg
WHISPER_CPP_LANGUAGE=en
WHISPER_CPP_THREADS=4
WHISPER_CPP_TIMEOUT_MS=300000
WHISPER_CPP_SERVER_URL=
