{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memo Capture",
  "version": "0.1.0",
  "identifier": "com.paulmarshall.memocapture",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 5178 --strictPort",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5178",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Memo Capture",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "icon": []
  }
}
