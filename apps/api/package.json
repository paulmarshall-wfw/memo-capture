{
  "name": "@memo-capture/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "db:migrate": "tsx src/migrate.ts",
    "dev": "tsx src/index.ts",
    "test": "node --test --import tsx tests/*.test.ts",
    "test:postgres": "node --test --import tsx tests/postgres/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@memo-capture/config": "0.1.0",
    "@memo-capture/domain": "0.1.0",
    "pg": "8.13.1",
    "state-workflow-runtime": "file:../../../state-workflow-runtime"
  },
  "devDependencies": {
    "@types/pg": "8.11.10"
  }
}
